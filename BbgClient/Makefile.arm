TARGET = bbg_client_arm

CC = arm-linux-gnueabihf-gcc

INCLUDES = \
	-IInclude \
	-I../Libraries/Config/Inc \
	-I../Libraries/Logger/Inc \
	-I../Libraries/IpcProtocol/Inc

CFLAGS = \
	-Wall \
	-Wextra \
	-Wpedantic \
	-std=c11 \
	$(INCLUDES)

LDFLAGS = \
	-pthread

SRC = \
	Test/main.c \
	Src/bbg_client.c \
	../Libraries/Config/Src/config.c \
	../Libraries/Logger/Src/logger.c

OBJ = $(SRC:.c=.arm.o)

all: $(TARGET)

$(TARGET): $(OBJ)
	$(CC) $(OBJ) -o $(TARGET) $(LDFLAGS)

%.arm.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	rm -f $(OBJ)
	rm -f $(TARGET)
	find . -type f -name "*.arm.o" -delete

.PHONY: all clean
